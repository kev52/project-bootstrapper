{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_TOOL_INPUT_FILE_PATH\""
          },
          {
            "type": "command",
            "command": "npx eslint --fix \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | tail -20"
          },
          {
            "type": "command",
            "command": "npx vitest run --reporter=verbose 2>&1 | tail -20 || npx jest --passWithNoTests 2>&1 | tail -20"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '## Git Status' && git status --short && echo '## Active TODOs' && grep -r 'TODO:' src/ --include='*.ts' --include='*.tsx' 2>/dev/null | head -5 || echo 'No TODOs found'"
          }
        ]
      }
    ]
  }
}
